APP_ENV=development
APP_HOST=
APP_PORT=18080
# Host ports used by Docker Compose. Change either value if it is already in use.
BACKEND_PORT=18080
FRONTEND_PORT=13000
APP_DATABASE_PATH=./data/app.db
ENCRYPTION_KEY=replace-with-a-long-random-secret
JWT_SECRET=replace-before-adding-authentication
CORS_ALLOWED_ORIGINS=http://localhost:13000
DEFAULT_QUERY_TIMEOUT_SECONDS=30
MAX_QUERY_ROWS=200
MAX_OPEN_CONNECTIONS=10
MAX_CONCURRENT_QUERIES=4
NUXT_PUBLIC_API_BASE=http://localhost:18080/api
