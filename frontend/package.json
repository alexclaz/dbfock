{
  "name": "dbfock-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev --host 0.0.0.0 --port ${FRONTEND_PORT:-13000}",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt prepare && nuxt typecheck",
    "dev:wails": "nuxt dev --host 127.0.0.1 --port 1420",
    "generate:wails": "nuxt generate && node scripts/copy-wails-assets.mjs",
    "dev:desktop": "cd ../backend && wails dev",
    "build:desktop": "cd ../backend && wails build"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@fontsource/ibm-plex-mono": "^5.3.0",
    "@fontsource/ibm-plex-sans": "^5.3.0",
    "@fontsource/source-code-pro": "^5.3.0",
    "@lezer/highlight": "^1.2.3",
    "@nuxt/icon": "^2.3.1",
    "@nuxtjs/tailwindcss": "6.14.0",
    "@pinia/nuxt": "1.0.1",
    "nuxt": "4.5.0",
    "pinia": "^4.0.2",
    "vue": "^3.5.24"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.16.0",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.7"
  }
}
